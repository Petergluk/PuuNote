# Копируйте этот файл в .env (не добавляя его в гит)
# Впишите сюда свой Gemini API ключ
# ВАЖНО: Размещение ключа на клиенте является осознанным архитектурным решением
# для данного бесплатного демо-приложения. Не используйте ключи с включенным биллингом.
VITE_GEMINI_API_KEY=your_api_key_here

# Если вы хотите использовать этот стенд глобально, 
# вы также можете использовать переменную:
# VITE_GLOBAL_GEMINI_API_KEY=your_api_key_here
